{
  "name": "prisim-r2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "next-on-pages",
    "preview": "next-on-pages && wrangler pages dev",
    "deploy": "next-on-pages && wrangler pages deploy",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "db:gen": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "workerd"
    ],
    "patchedDependencies": {
      "@aws-sdk/xml-builder@3.972.24": "patches/@aws-sdk__xml-builder@3.972.24.patch"
    }
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@aws-sdk/client-s3": "3.1050.0",
    "@aws-sdk/s3-request-presigner": "3.1050.0",
    "@tanstack/react-query": "5.100.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "^15.4.0",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ulid": "3.0.2",
    "zod": "4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260520.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.0",
    "prettier": "^3.8.3",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vercel": "^54.2.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.93.0"
  }
}
